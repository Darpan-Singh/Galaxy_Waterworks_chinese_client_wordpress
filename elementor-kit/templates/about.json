              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "從根源解決滲漏，還您安心居所",
                "header_size": "h2",
                "align": "left",
                "title_color": "#1A1A1A",
                "typography_typography": "custom",
